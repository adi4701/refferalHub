PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/referralhub?retryWrites=true&w=majority
JWT_SECRET=<generate_with_node_-e_crypto.randomBytes(32).toString('hex')>
JWT_EXPIRES_IN=30d
REFRESH_TOKEN_SECRET=<generate_with_node_-e_crypto.randomBytes(64).toString('hex')>
CLIENT_URL=http://localhost:5173
CLOUDINARY_CLOUD_NAME=<your_cloudinary_cloud_name>
CLOUDINARY_API_KEY=<your_cloudinary_api_key>
CLOUDINARY_API_SECRET=<your_cloudinary_api_secret>
